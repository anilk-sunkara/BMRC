pipeline {
    agent any

    stages {

        stage('Install Dependencies') {
            steps {
                dir('BMRC_Framework_New') {
                    bat '''
                    "C:/Users/Anil Kumar/AppData/Local/Programs/Python/Python313/python.exe" -m pip install -r requirements.txt
                    '''
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('BMRC_Framework_New') {
                    bat '''
                    if not exist reports mkdir reports
                    "C:/Users/Anil Kumar/AppData/Local/Programs/Python/Python313/python.exe" -m pytest testdata/testcases --html=reports/report.html --self-contained-html
                    '''
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'BMRC_Framework_New/reports/report.html', allowEmptyArchive: true
        }
    }
}