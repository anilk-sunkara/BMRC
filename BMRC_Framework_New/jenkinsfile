pipeline {
    agent any

    environment {
        PYTHON = '"C:/Users/Anil Kumar/AppData/Local/Programs/Python/Python313/python.exe"'
    }

    stages {

        stage('Install Dependencies') {
            steps {
                dir('BMRC_Framework_New') {
                    bat """
                    %PYTHON% -m pip install --upgrade pip
                    %PYTHON% -m pip install -r requirements.txt
                    """
                }
            }
        }

        stage('Run Tests') {
            steps {
                dir('BMRC_Framework_New') {
                    bat """
                    if not exist reports mkdir reports
                    %PYTHON% -m pytest testdata/testcases --html=reports/report.html --self-contained-html
                    """
                }
            }
        }
    }

    post {
        always {
            archiveArtifacts artifacts: 'BMRC_Framework_New/reports/report.html', allowEmptyArchive: true
            junit allowEmptyResults: true, testResults: 'BMRC_Framework_New/reports/*.xml'
        }

        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }
    }
}